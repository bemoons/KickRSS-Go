db_path: myrss.db
port: 8888
fetch_interval_minutes: 15
ai:
  default:
    base_url: http://localhost:9999/v1
    api_key: your_api_key_here
    model: qwen-local
  tasks:
    classify:
      batch_size: 25
      max_concurrency: 2
    seed:
      model: qwen-local
    summary:
      max_tokens: null
    chat:
      base_url: null
      model: null
      max_tokens: 1200
      api_key: null
  pregenerate: false
  stream: true
  auto_summary: true
  summary_length: medium
  summary_language: zh
fulltext:
  fetcher: trafilatura
  rendering_service_url: http://localhost:3100/render
  min_text_chars: 200
classify:
  promote_threshold: 5
system_language: zh
interest_profile_enabled: true
